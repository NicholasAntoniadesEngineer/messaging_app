{
  "name": "secure-messenger",
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone end-to-end encrypted messaging web app (X25519 + XSalsa20-Poly1305) on Supabase",
  "scripts": {
    "dev": "vite",
    "build:css": "npx @tailwindcss/cli -i ./lib/auth_db/shared/styles/main.css -o ./lib/auth_db/shared/styles/main-compiled.css --minify",
    "build": "npm run build:css && vite build",
    "watch:css": "npx @tailwindcss/cli -i ./lib/auth_db/shared/styles/main.css -o ./lib/auth_db/shared/styles/main-compiled.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "6.3.6"
  }
}
